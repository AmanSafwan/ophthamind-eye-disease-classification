# Application
APP_NAME=OphthaMind AI
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/eye_system

# Database (XAMPP MySQL)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=eye_system
DB_USER=root
DB_PASS=

# Session
SESSION_TIMEOUT=3600
SESSION_NAME=eye_system_session

# Uploads
UPLOAD_DIR=public/upload/
MAX_UPLOAD_SIZE=5242880
ALLOWED_TYPES=jpg,jpeg,png

# AI service
PYTHON_PATH=C:\xampp\htdocs\eye_system\venv\Scripts\python.exe
ENABLE_AI=true
AI_PORT=5001
ENABLE_REGISTRATION=false
